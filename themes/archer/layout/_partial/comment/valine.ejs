<%_ if (theme.comment && theme.comment.valine_appId && theme.comment.valine_appKey) { _%>
    <div id="comment"></div>
    <script>
        new Valine({
            el: '#comment',
            notify:false,
            verify:false,
            appId: "<%- theme.comment.valine_appId %>",
            appKey: "<%- theme.comment.valine_appKey %>",
            placeholder: "<%- theme.comment.valine_placeHolder %>",
            path:window.location.pathname,
            avatar:'mm'
        });
    </script>
<%_ } _%>
